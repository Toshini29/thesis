# A subset of (condec)DECLARE formalized in ontology and rules
@prefix : <http://infs.cit.tum.de/karibdis/baseontology/> .
@base <http://infs.cit.tum.de/karibdis/baseontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ex: <http://infs.cit.tum.de/karibdis/rules/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix declare: <http://infs.cit.tum.de/karibdis/declare/> .


declare:init rdf:type owl:ObjectProperty;
    rdfs:domain :Activity ;
    rdfs:range :Activity ;
    rdfs:comment "The first activity for this process.".

declare:InitRule a sh:NodeShape ;
    sh:targetClass :Case ;
	sh:rule [
        a sh:SPARQLRule ;
		sh:prefixes : ;
		sh:construct """
            PREFIX declare: <http://infs.cit.tum.de/karibdis/declare/>
			CONSTRUCT {
				?tail :instanceOf ?init .
			} WHERE { 
                ?init declare:init ?init . # TODO: check that it's the only one - and make it process specific ...
                ?tail :partOf $this .
                FILTER NOT EXISTS {
                    ?tail :instanceOf ?any.
                }
                FILTER NOT EXISTS {
                    ?other :partOf $this .
                    FILTER(?other != ?tail)
                }
            }
        """ ;
	] .


declare:chainresponse rdf:type owl:ObjectProperty;
    rdfs:domain :Activity ;
    rdfs:range :Activity ;
    rdfs:comment "If the subject activity occurs, the object activity must occur next.".

declare:ChainResponseRule a sh:NodeShape ;
    sh:targetClass :Case ;
	sh:rule [
        a sh:SPARQLRule ;
		sh:prefixes ex: ;
		sh:construct """
            PREFIX declare: <http://infs.cit.tum.de/karibdis/declare/>
			CONSTRUCT {
				?tail :instanceOf ?b .
			} WHERE { 
                ?tail :partOf $this .
                 FILTER NOT EXISTS {
                    ?tail :instanceOf ?any.
                }
				BIND (ex:lastCompleted($this) AS ?last) .
                ?last :instanceOf ?a.
                ?a declare:chainresponse ?b.
            }
        """ ;
	] .


declare:exactly_one rdf:type owl:ObjectProperty;
    rdfs:domain :Activity ;
    rdfs:range :Activity ;
    rdfs:comment "This activity must occur exactly once.".


declare:AtMostOnce a sh:PropertyShape ;
    sh:targetClass :Task ;
    sh:path :instanceOf__hypothetical;
    sh:severity sh:Info;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Activity '{?activity}' should be executed only once." ;
        sh:select """
            SELECT $this ?activity (-1 AS ?value)
            WHERE { 
                $this :instanceOf__hypothetical ?activity .
                $this :partOf ?case .
                ?activity declare:exactly_one ?activity . 
                {
                    SELECT (COUNT(distinct ?othertask) as ?count)
                    WHERE {
                        ?othertask :partOf ?case .
                        ?othertask :instanceOf ?activity .
                    }
                }
                FILTER(?count > 1)
            }
        """ ;
    ] .

declare:AtLeastOnce a sh:PropertyShape ;
    sh:targetClass :Task ;
    sh:path :instanceOf__hypothetical;
    sh:severity sh:Info;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Activity '{?activity}' should still be executed." ;
        sh:select """
            SELECT $this ?activity (IF(STR(?activity) = STR(?thisactivity), 0.2,-0.1) as ?value)
            WHERE { 
                $this :partOf ?case .
                $this :instanceOf__hypothetical ?thisactivity .
                ?activity declare:exactly_one ?activity .
                FILTER NOT EXISTS {
                    ?othertask :instanceOf ?activity .
                }
                
            }
        """ ;
    ] .