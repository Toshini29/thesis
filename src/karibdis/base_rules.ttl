@prefix : <http://infs.cit.tum.de/karibdis/baseontology/> .
@prefix rules: <http://infs.cit.tum.de/karibdis/rules/> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .


rules:ExtendStaleCasesRule a sh:NodeShape ;
    sh:targetClass :Case ;
    sh:condition rules:ExtendStaleCasesRule; 
	sh:rule [
        a sh:SPARQLRule ;
		sh:construct """
			CONSTRUCT {
				?next :partOf $this .
				?next rdf:type :Task .
			} WHERE {
                FILTER NOT EXISTS {
                    ?task :partOf $this .
                    FILTER NOT EXISTS { ?task :completedAt ?any }
                }
                FILTER NOT EXISTS {
                    $this :isClosed true
                }
				BIND (rules:nexttask($this) AS ?next) .
			}
        """ ;
	] .


rules:nexttask
    a sh:SPARQLFunction ;
    sh:parameter [
        sh:path rules:op1 ;
        sh:datatype :Case ;
        sh:description "The case" ;
    ] ;
    sh:returnType :Task ;
    sh:select """
        SELECT (URI(CONCAT(STRBEFORE(str(?op1), "Case_"), "Task_", STRAFTER(str(?op1), "Case_"), "_", STR(COUNT(?c) + 1))) AS ?result)
        WHERE {
            OPTIONAL {?c :partOf ?op1. }
        }
    """.


rules:lastCompleted
    a sh:SPARQLFunction ;
    sh:parameter [
        sh:path rules:op1 ;
        sh:datatype :Case ;
        sh:description "The case" ;
    ] ;
    sh:returnType :Task ;
    sh:select """
        SELECT (SAMPLE(?task) as ?result) # Note: SAMPLE is a fix for pySHACL error when returning and binding empty list; might not be compliant to SPARQL standard 
        WHERE {
            ?task :partOf ?op1.
            {
                SELECT (MAX(?completedAt) AS ?maxCompletedAt) WHERE {
                    ?task2 :partOf ?op1 .
                    ?task2 :completedAt ?completedAt .
                }
            }
            ?task :completedAt ?maxCompletedAt .
        }
        LIMIT 1
    """.

rules:ExecutionPermissionConstraint a sh:PropertyShape ;
    sh:targetClass :Task ;
    sh:path :performedBy__hypothetical;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "The resource '{?resource}' is not allowed to perform the activity '{?activity}'" ;
        sh:select """
            SELECT $this ?activity ?resource
            WHERE {
                $this :performedBy__hypothetical ?resource .
                $this :instanceOf ?activity .
                FILTER NOT EXISTS { 
                    ?resource :hasRole* / ^:canBeExecutedBy ?activity .
                }
            }
        """ ;
    ] .

rules:ExecutionPermissionReward a sh:PropertyShape ;
    sh:targetClass :Task ;
    sh:path :performedBy__hypothetical;
    sh:severity sh:Info;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Resource has relevant role(s) for activity '{?activity}'" ;
        sh:select """
            SELECT $this ?activity ?resource (2 AS ?value)
            WHERE {
                $this :performedBy__hypothetical ?resource .
                $this :instanceOf ?activity .
                FILTER EXISTS { 
                    ?resource :hasRole* / ^:canBeExecutedBy ?activity .
                }
            }
        """ ;
    ] .