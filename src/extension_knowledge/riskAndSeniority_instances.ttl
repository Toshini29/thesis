@prefix ApplicationType: <http://example.org/instances/ApplicationTypes/> .
@prefix LoanGoal: <http://example.org/instances/LoanGoals/> .
@prefix RiskClass: <http://example.org/instances/RiskClasss/> .
@prefix Seniority: <http://example.org/instances/Senioritys/> .
@prefix activity: <http://example.org/instances/activitys/> .
@prefix case: <http://example.org/instances/cases/> .
@prefix four_eyes: <http://example.org/instances/four_eyes/> .
@prefix relation: <http://example.org/relations/> .
@prefix resource: <http://example.org/instances/resources/> .
@prefix task: <http://example.org/instances/tasks/> .
@prefix type: <http://example.org/types/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

LoanGoal:Existing%20loan%20takeover a type:LoanGoal ;
    relation:RiskClass RiskClass:High .

LoanGoal:Car a type:LoanGoal ;
    relation:RiskClass RiskClass:High .

LoanGoal:Home%20improvement a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Other%2C%20see%20explanation a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Unknown a type:LoanGoal ;
    relation:RiskClass RiskClass:Medium .

LoanGoal:Remaining%20debt%20home a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Not%20speficied a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Extra%20spending%20limit a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Caravan%20%2F%20Camper a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Motorcycle a type:LoanGoal ;
    relation:RiskClass RiskClass:Medium .

LoanGoal:Boat a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Tax%20payments a type:LoanGoal ;
    relation:RiskClass RiskClass:Low .

LoanGoal:Business%20goal a type:LoanGoal ;
    relation:RiskClass RiskClass:Medium .

LoanGoal:Debt%20restructuring a type:LoanGoal ;
    relation:RiskClass RiskClass:High .


# TODO Consider making these named individuals and part of the ontology (as described in https://github.com/RDFLib/pySHACL/issues/187) (doesn't really seem to work though)
RiskClass:High a type:RiskClass ;
    relation:minSeniority Seniority:High .

RiskClass:Medium a type:RiskClass ;
    relation:minSeniority Seniority:Medium .

RiskClass:Low a type:RiskClass ;
    relation:minSeniority Seniority:Low .


Seniority:High a type:Seniority ;
    relation:greaterEq Seniority:Low, Seniority:High, Seniority:Medium .

Seniority:Medium a type:Seniority ;
    relation:greaterEq Seniority:Low, Seniority:Medium .

Seniority:Low a type:Seniority ;
    relation:greaterEq Seniority:Low .