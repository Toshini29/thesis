@prefix activity: <http://example.org/instances/activitys/> .
@prefix case: <http://example.org/instances/cases/> .
@prefix task: <http://example.org/instances/tasks/> .
@prefix relation: <http://example.org/relations/> .
@prefix resource: <http://example.org/instances/resources/> .
@prefix type: <http://example.org/types/> .
@prefix RiskClass: <http://example.org/instances/RiskClasss/> .
@prefix Seniority: <http://example.org/instances/Senioritys/> .

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://foobar.org/> .

@prefix activity: <http://example.org/instances/activitys/> .
@prefix case: <http://example.org/instances/cases/> .
@prefix task: <http://example.org/instances/tasks/> .
@prefix relation: <http://example.org/relations/> .
@prefix resource: <http://example.org/instances/resources/> .
@prefix type: <http://example.org/types/> .
@prefix RiskClass: <http://example.org/instances/RiskClasss/> .
@prefix Seniority: <http://example.org/instances/Senioritys/> .

@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix ex: <http://foobar.org/> .

ex:RiskSeniorityRequirement a sh:PropertyShape ;
    sh:targetClass type:resource ;
    sh:path relation:performedBy__hypothetical;
    sh:severity sh:Info;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Seniority '{?seniority}' not sufficient for risk class '{?riskclass}' of loan goal '{?loangoal}'" ;
        sh:select """
            SELECT  $this (-2 AS ?value) ?seniority ?loangoal ?riskclass
            WHERE {
                $this relation:Seniority ?seniority .
                $this ^relation:performedBy__hypothetical / relation:partOf / relation:LoanGoal ?loangoal .
                ?loangoal relation:RiskClass ?riskclass .
                ?riskclass relation:minSeniority ?minseniority . 
                FILTER NOT EXISTS { 
                    ?seniority relation:greaterEq* ?minseniority .
                }
            }
        """ ;
    ] .

ex:RiskSeniorityReward a sh:PropertyShape ;
    sh:targetClass type:resource ;
    sh:path relation:performedBy__hypothetical;
    sh:severity sh:Info;
    sh:sparql [
        a sh:SPARQLConstraint ;
        sh:message "Seniority '{?seniority}' is sufficient for risk class '{?riskclass}' of loan goal '{?loangoal}'" ;
        sh:select """
            SELECT  $this (1 AS ?value) ?seniority ?loangoal ?riskclass
            WHERE {
                $this relation:Seniority ?seniority .
                $this ^relation:performedBy__hypothetical / relation:partOf / relation:LoanGoal ?loangoal .
                ?loangoal relation:RiskClass ?riskclass .
                ?riskclass relation:minSeniority ?minseniority . 
                FILTER EXISTS { 
                    ?seniority relation:greaterEq* ?minseniority .
                }
            }
        """ ;
    ] .
