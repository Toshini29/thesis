PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX mondo: <http://purl.obolibrary.org/obo/>

DESCRIBE ?node WHERE {
  ?node ^rdfs:subClassOf* / rdfs:label ?label .
  FILTER(?label = "leukocyte disorder" || ?label = "multiple organ dysfunction syndrome" || ?label = "diabetes mellitus" || ?label = "infectious disease with sepsis") .
} 